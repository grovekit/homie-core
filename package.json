{
  "name": "@grovekit/homie-core",
  "version": "0.0.1-alpha.4",
  "description": "A GroveKit library that provides typings and utilities for working with the Homie MQTT convention throughout the rest of the GroveKit stack.",
  "main": "dist/index.js",
  "type": "module",
  "private": false,
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "test": "node --test dist/**/*.test.js",
    "ts:clean": "rm -rf ./dist && rm -f ./tsconfig.tsbuildinfo",
    "ts:build": "npm run ts:clean && tsc",
    "ts:watch": "npm run ts:clean && tsc --watch",
    "build": "npm run ts:build"
  },
  "author": "Jacopo Scazzosi <jacopo@scazzosi.com>",
  "license": "MIT",
  "homepage": "https://github.com/grovekit/homie-core",
  "bugs": "https://github.com/grovekit/homie-core/issues",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/grovekit/homie-core.git"
  },
  "dependencies": {
    "@deepkit/type": "^1.0.19"
  },
  "devDependencies": {
    "@deepkit/type-compiler": "^1.0.19",
    "@types/node": "^25.5.0",
    "typescript": "^6.0.2"
  },
  "files": [
    "dist/**/*.js",
    "dist/**/*.d.ts",
    "!dist/**/*.test.js",
    "!dist/**/*.test.d.ts"
  ]
}
